# 抓取页数
maxPageSize=10

# 点值 > minVoted 才推送
minVoted=10

# 评论数 > minComments 才推送
minComments=2

# 优惠数量 >= MIN_PUSH_SIZE 才推送
MIN_PUSH_SIZE=20

# 是否输出详细日志
detail=false

# 邮箱推送，可选
emailHost=smtp.qq.com
emailPort=465
emailAccount=
emailPassword=

# WxPusher 极简推送，可选
spt=

# 可选：固定 cookie。通常不建议使用，优先 selenium 自动获取
# COOKIE=__ckguid=xxx; w_tsfp=xxx
